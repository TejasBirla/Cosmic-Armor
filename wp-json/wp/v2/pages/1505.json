pen\"\n            x-transition\n            x-on:click=\"close\"\n            class=\"relative flex items-center justify-center min-h-screen p-4\"\n        >\n            <div\n                x-on:click.stop\n                x-trap.noscroll.inert=\"isOpen\"\n                class=\"relative w-full max-w-4xl overflow-y-auto bg-white shadow-lg rounded-xl\"\n            >\n                                    <div x-ref=\"videocontainer\" class=\"aspect-video\">\n                                    <div class=\"relative z-10\">\n\n<figure class=\"wp-block-embed is-type-video is-provider-youtube wp-block-embed-youtube wp-embed-aspect-16-9 wp-has-aspect-ratio\"><div class=\"wp-block-embed__wrapper\">\n<iframe title=\"CosmicArmor SaaS - Demo 20 February 2024\" width=\"500\" height=\"281\" src=\"https:\/\/www.youtube.com\/embed\/-JJQSnZRFiw?feature=oembed\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\" referrerpolicy=\"strict-origin-when-cross-origin\" allowfullscreen><\/iframe>\n<\/div><\/figure>\n\n<\/div>\n                                    <\/div>\n                            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n<\/div>\n\n\n\n<div class=\"wp-block-column flex flex-col justify-center items-center is-layout-flow wp-block-column-is-layout-flow\">\n<div class=\"wp-block-group\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<h2 class=\"wp-block-heading\">See it in action<\/h2>\n\n\n\n<p class=\"md:max-w-96\">Discover how CosmicArmor simplifies cloud security. Watch our demo to see real-time solutions for complex security challenges.<\/p>\n\n\n\n<div class=\"wp-block-buttons mt-9 is-layout-flex wp-block-buttons-is-layout-flex\">\n<div class=\"wp-block-button is-style-outline js-modal-trigger is-style-outline--2\"><a class=\"wp-block-button__link wp-element-button\" href=\"#demo-video\">Watch Now<\/a><\/div>\n<\/div>\n<\/div><\/div>\n<\/div>\n<\/div>\n<\/div><\/div>\n\n\n\n<div class=\"wp-block-group e-lines-y e-break-out-to-lines\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<div class=\"wp-block-columns e-accent-divider py-12 md:py-32 is-layout-flex wp-container-core-columns-is-layout-4 wp-block-columns-is-layout-flex\">\n<div class=\"wp-block-column flex flex-col justify-center items-center is-layout-flow wp-block-column-is-layout-flow\">\n<figure class=\"wp-block-image size-full e-screenshot js-tailcraft-animate-in\"><img decoding=\"async\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/prowler-screenshot-scan-overview-severity@2x.jpg\" alt=\"\" class=\"wp-image-535\"\/><\/figure>\n<\/div>\n\n\n\n<div class=\"wp-block-column flex flex-col justify-center items-center is-layout-flow wp-block-column-is-layout-flow\">\n<div class=\"wp-block-group md:max-w-sm 2xl:max-w-md\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<h2 class=\"wp-block-heading\">Empower your decisions with data-driven insights<\/h2>\n\n\n\n<p class=\"c-note\">Leverage detailed analytics to gain insights into security trends and patterns over time.<\/p>\n\n\n\n<p class=\"c-note\">Use data visualizations to make informed decisions about security strategies and resource allocation.<\/p>\n\n\n\n<p class=\"c-note\">Benefit from historical data comparisons to track your progress and improvement in your CSPM.<\/p>\n<\/div><\/div>\n<\/div>\n<\/div>\n<\/div><\/div>\n\n\n\n<div class=\"wp-block-group mb-50 mt-35\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<h2 class=\"wp-block-heading has-text-align-center mb-22\">Dashboard Details<\/h2>\n\n\n\n<div class=\"wp-block-group c-card-grid js-tailcraft-animate\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<div \n    class=\"