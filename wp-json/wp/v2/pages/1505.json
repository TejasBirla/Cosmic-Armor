er-2024\/img\/spoke-kubernetes-logo.png\"\n                    class=\"max-w-[150px] w-[53%]\"\n                >\n            <\/div>\n\n\n                        <div\n                class=\"bg-dark rounded-full flex items-center justify-center border-2 border-white w-[25.8%] aspect-square absolute left-1\/2 top-1\/2 -translate-x-1\/2 -translate-y-1\/2\"\n            >\n                <img decoding=\"async\"\n                    src=\"https:\/\/prowler.com\/wp-content\/themes\/prowler-2024\/img\/web-logo-prowler-p.png\"\n                    class=\"max-w-[150px] w-[53%]\"\n                >\n            <\/div>\n\n\n        <\/div>\n\n<\/div>\n\n\n\n<div class=\"wp-block-column flex flex-col justify-center items-center is-layout-flow wp-block-column-is-layout-flow\">\n<div class=\"wp-block-group md:max-w-sm 2xl:max-w-md\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<h2 class=\"wp-block-heading\">Security that matches your vision<\/h2>\n\n\n\n<p class=\"c-note\"><strong>Unmatched Flexibility:<\/strong> Tailor your security with over 500 checks across AWS, Azure, GCP and Kubernetes.<\/p>\n\n\n\n<p class=\"c-note\"><strong>Community Powered:<\/strong> Benefit from the collective expertise of a vibrant community. Share, innovate, and evolve security practices together, making security a collective strength.<\/p>\n\n\n\n<p class=\"c-note\"><strong>Complete Transparency: <\/strong>With CosmicArmor, there are no black boxes. You have the visibility and control to understand, tweak, and fully own your security processes and tools.<\/p>\n<\/div><\/div>\n<\/div>\n<\/div>\n<\/div><\/div>\n\n\n\n<div class=\"wp-block-group e-lines-y e-break-out-to-lines\"><div class=\"wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained\">\n<div class=\"wp-block-columns e-accent-divider py-12 md:py-32 e-reverse-columns is-layout-flex wp-container-core-columns-is-layout-3 wp-block-columns-is