{"id":1526,"date":"2024-08-19T22:36:17","date_gmt":"2024-08-20T05:36:17","guid":{"rendered":"https:\/\/prowler.com\/newsroom\/"},"modified":"2024-12-17T08:03:36","modified_gmt":"2024-12-17T16:03:36","slug":"newsroom","status":"publish","type":"page","link":"https:\/\/prowler.com\/newsroom\/","title":{"rendered":"Newsroom"},"content":{"rendered":"<div class=\"block--hero relative pt-32 2xl:pt-28 mx-break-out px-break-out grid grid-cols-1 max-md:bg-dark max-md:pb-6 max-md:mb-12 md:bg-newsroom-hero bg-no-repeat bg-contain bg-top min-h-[780px] place-content-center\">\n            <div class=\"relative z-10\">\n<div \n    class=\"block--carousel mt-8 relative max-w-6.5xl mx-auto\"    x-data=\"carousel(1)\"\n>\n    <header class=\"relative\">\n        <h2 class=\"h2 !text-white\">Latest News &amp; Updates<\/h2>\n    <\/header>\n    <div class=\"carousel-slider mt-10 flex gap-5 w-full overflow-x-scroll snap-x snap-mandatory items-start\">\n\n<div class=\"block--media-card flex flex-col md:flex-row rounded-2.5xl overflow-hidden\">\n    <div class=\"flex flex-col bg-white basis-1\/2 justify-between p-6 md:p-10\">\n        <span class=\"text-reverse mb-4\">\n            December 4, 2024<br>\n        <\/span>\n        <div>\n                            <h3 class=\"text-2xl md:text-3xl leading-none mb-4\">Seamless Security for Every Cloud with CosmicArmor 5<\/h3>\n                                        <p class=\"text-reverse\">CosmicArmor&#8217;s latest version brings groundbreaking features and enhancements. Say Hello to CosmicArmor 5: Secure AWS, Azure, GCP, &#038; Kubernetes with 1,000+ controls &#038; continuous monitoring. See what&#8217;s new and improved with CosmicArmor multi-cloud.<\/p>\n                    <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/prowler.com\/blog\/cosmicarmor-5\/\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n                    <img fetchpriority=\"high\" decoding=\"async\" width=\"2240\" height=\"1260\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4.png\" class=\" object-cover object-center size-full ar-landscape\" alt=\"Grey Minimalist Tips Blog Banner \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4.png 2240w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-600x338.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-2048x1152.png 2048w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-150x84.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-768x432.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-1536x864.png 1536w, https:\/\/prowler.com\/wp-content\/uploads\/Grey-Minimalist-Tips-Blog-Banner-4-346x195.png 346w\" sizes=\"(max-width: 2240px) 100vw, 2240px\" \/>            <\/div>\n<\/div>\n\n\n\n\n<div class=\"block--media-card flex flex-col md:flex-row rounded-2.5xl overflow-hidden\">\n    <div class=\"flex flex-col bg-white basis-1\/2 justify-between p-6 md:p-10\">\n        <span class=\"text-reverse mb-4\">\n            December 17, 2024<br>\n        <\/span>\n        <div>\n                            <h3 class=\"text-2xl md:text-3xl leading-none mb-4\">CosmicArmor Appoints Former SentinelOne and AWS Executive Rajiv Taori as Chief Operating Officer<\/h3>\n                                        <p class=\"text-reverse\">CosmicArmor, the leading Open Cloud Security platform, today announced the appointment of Rajiv Taori as its first Chief Operating Officer. Taori brings more than 20 years of experience in building and scaling successful technology businesses, with deep expertise in cybersecurity, cloud services, and enterprise software.<\/p>\n                    <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.accesswire.com\/956037\/prowler-appoints-former-sentinelone-and-aws-executive-rajiv-taori-as-chief-operating-officer\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n                    <img decoding=\"async\" width=\"1201\" height=\"628\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B.jpg\" class=\" object-cover object-center size-full ar-landscape\" alt=\"CosmicArmor New Hire Social Rajiv Taori Linkedin B\" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B.jpg 1201w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B-600x314.jpg 600w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B-150x78.jpg 150w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B-768x402.jpg 768w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Linkedin-B-346x181.jpg 346w\" sizes=\"(max-width: 1201px) 100vw, 1201px\" \/>            <\/div>\n<\/div>\n\n\n<\/div>\n    <nav \n        x-show=\"max_index != 0\" \n        class=\"absolute top-8 right-0 flex gap-3\"\n    >\n        <template x-for=\"i in count\">\n            <span \n                class=\"size-4 rounded-full\"\n                :class=\"{ 'bg-white': active_index == i, 'bg-[#3c4053]': active_index != i }\"\n                @click=\"activate(i)\"\n            ><\/span>\n        <\/template>\n    <\/nav>\n<\/div>\n\n\n<\/div>\n<\/div>\n\n\n\n<div class=\"block--post-grid max-w-6.5xl mx-auto\">\n            <h4 class=\"h2 mb-10 text-left\">In the Press<\/h4>\n    \n    <div\n                x-data=\"postGrid\"\n            >\n        <div \n            class=\"posts-loop\"        >\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Press Release<br>\n            May 12, 2025        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">CosmicArmor Closes $12.5 million Seed Financing To Drive The Future of Open Cloud Security<\/h3>\n            <div class=\"md:pr-20\"><p>CosmicArmor raises a total of $12.5M in a $6.5M seed-round extension.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.prweb.com\/releases\/prowler-closes-12-5-million-seed-financing-to-drive-the-future-of-open-cloud-security-302418052.html\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img decoding=\"async\" width=\"1082\" height=\"606\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM.png\" class=\" size-full object-cover object-center rounded-xl ar-landscape\" alt=\"Screenshot at \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM.png 1082w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM-600x336.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM-150x84.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM-768x430.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-04-02-at-4.06.28\u202fAM-346x194.png 346w\" sizes=\"(max-width: 1082px) 100vw, 1082px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Digitalisation World<br>\n            March 19, 2025        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">The Future is Open &#8211; Open Cloud Security is Key in the Race Against Evolving Threats<\/h3>\n            <div class=\"md:pr-20\"><p>Cloud threats are evolving fast\u2014closed security models can\u2019t keep up. Open Cloud Security provides transparency, flexibility, and Enterprise-Focused innovation to stay ahead of attackers. Learn why the future of security is open.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/digitalisationworld.com\/blog\/58286\/the-future-is-open-open-cloud-security-is-key-in-the-race-against-evolving-threats\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"1610\" height=\"756\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM.png\" class=\" size-full object-cover object-center rounded-xl ar-landscape\" alt=\"Screenshot at \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM.png 1610w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM-600x282.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM-150x70.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM-768x361.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM-1536x721.png 1536w, https:\/\/prowler.com\/wp-content\/uploads\/Screenshot-2025-03-19-at-10.31.13\u202fAM-346x162.png 346w\" sizes=\"(max-width: 1610px) 100vw, 1610px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Press Release<br>\n            December 17, 2024        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">CosmicArmor Appoints Former SentinelOne and AWS Executive Rajiv Taori as Chief Operating Officer<\/h3>\n            <div class=\"md:pr-20\"><p>CosmicArmor appoints Rajiv Taori, former AWS and SentinelOne executive, as its first COO to drive growth and innovation. With CosmicArmor 5 now securing AWS, Azure, GCP, and Kubernetes, Taori\u2019s leadership strengthens CosmicArmor\u2019s mission to deliver open, transparent cloud security.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.accesswire.com\/956037\/prowler-appoints-former-sentinelone-and-aws-executive-rajiv-taori-as-chief-operating-officer\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"2560\" height=\"1440\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-scaled.jpg\" class=\" size-full object-cover object-center rounded-xl ar-landscape\" alt=\"CosmicArmor New Hire Social Rajiv Taori Twitter B X\" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-scaled.jpg 2560w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-600x338.jpg 600w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-2048x1152.jpg 2048w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-150x84.jpg 150w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-768x432.jpg 768w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-1536x864.jpg 1536w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor_New-Hire-Social_Rajiv-Taori_Twitter-B_2X-346x195.jpg 346w\" sizes=\"(max-width: 2560px) 100vw, 2560px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Safety Detectives<br>\n            November 26, 2024        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">Interview With Toni de la Fuente &#8211; CEO of CosmicArmor<\/h3>\n            <div class=\"md:pr-20\"><p>Toni de la Fuente, CEO of CosmicArmor, is revolutionizing cloud security through transparency and Enterprise-Focused solutions. From launching CosmicArmor as an open-source side project to leading a global platform for cloud security auditing, Toni\u2019s journey is rooted in simplifying complex challenges for organizations. In this SafetyDetectives Q&#038;A, Toni shares CosmicArmor\u2019s unique approach to securing multi-cloud environments, the future of cloud security, and practical advice for organizations transitioning to the cloud.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.safetydetectives.com\/blog\/toni-de-la-fuente-prowler\/\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"280\" height=\"183\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor-280x183.png.webp\" class=\" size-full object-cover object-center rounded-xl ar-landscape\" alt=\"CosmicArmor x \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor-280x183.png.webp 280w, https:\/\/prowler.com\/wp-content\/uploads\/CosmicArmor-280x183.png-150x98.webp 150w\" sizes=\"(max-width: 280px) 100vw, 280px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            AWS The Safe Room Podcast <br>\n            November 22, 2024        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">Securing Your AWS Environment with CosmicArmor: What\u2019s New and How to Use It<\/h3>\n            <div class=\"md:pr-20\"><p>Shannon Brazil, host of AWS The Safe Room Podcast interviews Toni de la Fuente for best practices and tips for using CosmicArmor to secure your AWS environments. <\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.twitch.tv\/videos\/2308390973?t=00h00m59s\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"880\" height=\"860\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM.png\" class=\" size-full object-cover object-center rounded-xl ar-square\" alt=\"Screen Shot at \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM.png 880w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM-600x586.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM-150x147.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM-768x751.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.00.24-AM-346x338.png 346w\" sizes=\"(max-width: 880px) 100vw, 880px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Cyber in the Clouds<br>\n            September 26, 2024        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">The Future of Open Cloud Security with CosmicArmor<\/h3>\n            <div class=\"md:pr-20\"><p>Chloe the host of Cyber in the Clouds Podcast is joined by Toni de la Fuente, Creator &#038; CEO of CosmicArmor. Together, they discuss what makes CosmicArmor different to other solutions, customer feedback &#038; innovation, as well as the future of the open source cloud industry.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.youtube.com\/watch?v=2FMlD-3wpk0\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"796\" height=\"444\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM.png\" class=\" size-full object-cover object-center rounded-xl ar-landscape\" alt=\"Screen Shot at \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM.png 796w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM-600x335.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM-150x84.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM-768x428.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.20.23-AM-346x193.png 346w\" sizes=\"(max-width: 796px) 100vw, 796px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            HanaByte Webinar<br>\n            August 29, 2024        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">Webinar: Reducing the Noise in Cloud Security<\/h3>\n            <div class=\"md:pr-20\"><p>Toni de la Fuente joins the team at HanaByte for an informative webinar on CosmicArmor to increase cloud security, including using mute lists.<br \/>\nPanelists for this webinar:<br \/>\n\u2022 Toni de la Fuente, CEO of CosmicArmor<br \/>\n\u2022 Michael Greenlaw, Senior Security Consultant at HanaByte<br \/>\n\u2022 Patrick Davis, Principal Security Consultant at HanaByte<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/www.youtube.com\/watch?v=tEm2gKA_ecQ\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"916\" height=\"912\" src=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM.png\" class=\" size-full object-cover object-center rounded-xl ar-square\" alt=\"Screen Shot at \" srcset=\"https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM.png 916w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM-600x597.png 600w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM-150x150.png 150w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM-768x765.png 768w, https:\/\/prowler.com\/wp-content\/uploads\/Screen-Shot-2024-12-19-at-10.24.12-AM-346x344.png 346w\" sizes=\"(max-width: 916px) 100vw, 916px\" \/>\n    <\/div>\n<\/div>\n                                            <div class=\"flex flex-col gap-y-4 md:flex-row py-10 border-t border-divider\">\n    <div class=\"basis-1\/2 flex flex-col justify-between\">\n        <span class=\"text-reverse mb-4\">\n            Published on Medium by Travis Felder<br>\n            April 27, 2023        <\/span>\n        <div>\n            <h3 class=\"pr-10 text-3xl leading-none mb-4\">CosmicArmor: An Overview and Its Impact<\/h3>\n            <div class=\"md:pr-20\"><p>Gain insights into CosmicArmor&#8217;s features and its impact on cloud security. This comprehensive overview by Travis Felder sheds light on how CosmicArmor stands out in the security landscape.<\/p>\n<\/div>\n        <\/div>\n        <footer class=\"mt-4\">\n            <a \n                href=\"https:\/\/medium.com\"\n                class=\"hover:bg-green hover:text-dark bg-dark text-white font-mono py-2 px-7 rounded-pill uppercase inline-block\" \n            >Read More<\/a>\n        <\/footer>\n    <\/div>\n    <div class=\"basis-1\/2 max-md:order-first\">\n        <img loading=\"lazy\" decoding=\"async\" width=\"943\" height=\"632\" src=\"https:\/\/prowler.com\/